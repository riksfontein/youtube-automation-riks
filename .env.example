# Template — safe to commit. Copy to .env and fill in real values.
# .env itself is gitignored.

# === Anthropic (Claude API + MCP) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Subscribr (scripts, ideas, thumbnails) ===
SUBSCRIBR_API_KEY=
AE_CHANNEL_ID=56655
GIA_CHANNEL_ID=54904
BF_CHANNEL_ID=55636

# === vidIQ (competitor outliers) ===
VIDIQ_API_KEY=

# === ElevenLabs (TTS + Music) ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_GIA=
ELEVENLABS_VOICE_BF=
ELEVENLABS_VOICE_AE_LONG=
ELEVENLABS_VOICE_AE_SHORT=

# === Resend (email) ===
RESEND_API_KEY=
NOTIFICATION_EMAIL=info@croki.store
NOTIFICATION_FROM=noreply@croki.store

# === YouTube Data API v3 (OAuth, one refresh token per channel) ===
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN_AE=
YOUTUBE_REFRESH_TOKEN_GIA=
YOUTUBE_REFRESH_TOKEN_BF=

# === MCP server URLs ===
VIDIQ_MCP_URL=https://mcp.vidiq.com/mcp
NEXLEV_MCP_URL=https://prod.dashboard.nexlev.io/api/claude-mcp
